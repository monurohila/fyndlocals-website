<% const livePhone = (locals.liveConfig && locals.liveConfig.phone) ? locals.liveConfig.phone : site.phone; %>
<% const livePhoneHref = (locals.liveConfig && locals.liveConfig.phoneHref) ? locals.liveConfig.phoneHref : site.phoneHref; %>
<section class="cta-band">
  <div class="container">
    <div class="cta-band-inner">
      <div>
        <h2>Ready for a spotless home?</h2>
        <p>Call now — same-day service available in most cities.</p>
      </div>
      <a href="<%= livePhoneHref %>" class="btn-primary btn-large pulse-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        Call <%= livePhone %>
      </a>
    </div>
  </div>
</section>
