<% const livePhone = (locals.liveConfig && locals.liveConfig.phone) ? locals.liveConfig.phone : site.phone; %>
<% const livePhoneHref = (locals.liveConfig && locals.liveConfig.phoneHref) ? locals.liveConfig.phoneHref : site.phoneHref; %>
<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="nav-logo">Fynd<span>Locals</span></a>
        <p>Trusted cleaning services across the USA. Vetted professionals, same-day availability, 100% satisfaction guaranteed.</p>
        <a href="<%= livePhoneHref %>" class="footer-phone">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <%= livePhone %>
        </a>
      </div>
      <div class="footer-col">
        <h4>Services</h4>
        <% site.services.forEach(s => { %>
        <a href="/services/<%= s.slug %>"><%= s.name %></a>
        <% }) %>
      </div>
      <div class="footer-col">
        <h4>Top Locations</h4>
        <% site.cities.filter(c => c.phase === 1).forEach(c => { %>
        <a href="/house-cleaning-<%= c.slug %>-<%= c.stateAbbr.toLowerCase() %>"><%= c.name %>, <%= c.stateAbbr %></a>
        <% }) %>
        <% site.cities.filter(c => c.phase === 2).slice(0,4).forEach(c => { %>
        <a href="/house-cleaning-<%= c.slug %>-<%= c.stateAbbr.toLowerCase() %>"><%= c.name %>, <%= c.stateAbbr %></a>
        <% }) %>
        <a href="/locations">View all cities →</a>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <a href="/about">About Us</a>
        <a href="/blog">Blog</a>
        <a href="/contact">Contact</a>
        <a href="/get-a-quote">Get a Quote</a>
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/terms">Terms of Service</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>© <%= new Date().getFullYear() %> FyndLocals. All rights reserved.</p>
      <p>Serving cleaning professionals and homeowners across the United States.</p>
    </div>
  </div>
</footer>
<script src="/js/main.js"></script>
</body>
</html>
