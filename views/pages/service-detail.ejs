<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">Home</a> → <a href="/services">Services</a> → <%= service.name %></div>
    <div class="page-hero-inner">
      <div class="page-hero-left">
        <div class="service-hero-icon"><%= service.icon %></div>
        <h1><%= service.name %> Services</h1>
        <p class="page-desc"><%= service.desc %></p>
        <div class="feature-list">
          <% service.features.forEach(f => { %>
          <div class="feature-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg><span><%= f %></span></div>
          <% }) %>
        </div>
        <a href="<%= site.phoneHref %>" class="btn-primary btn-large pulse-btn" style="margin-top:32px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call <%= site.phone %> – Free Quote
        </a>
      </div>
      <div class="page-hero-right">
        <div class="price-card">
          <div class="price-tag"><%= service.price %></div>
          <h3>Book a <%= service.name %></h3>
          <p>Call us for an instant, no-obligation quote based on your home size and location.</p>
          <a href="<%= site.phoneHref %>" class="btn-primary" style="width:100%;justify-content:center;margin-top:16px;">Call Now</a>
          <ul class="price-includes">
            <li>✓ All supplies included</li>
            <li>✓ Background-checked cleaner</li>
            <li>✓ 100% satisfaction guarantee</li>
            <li>✓ Same-day availability</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Also Available</span>
      <h2>Other Services</h2>
    </div>
    <div class="services-grid">
      <% site.services.filter(s => s.slug !== service.slug).forEach(s => { %>
      <a href="/services/<%= s.slug %>" class="service-card">
        <div class="service-icon"><%= s.icon %></div>
        <h3><%= s.name %></h3>
        <p><%= s.shortDesc %></p>
        <div class="service-price"><%= s.price %></div>
        <span class="service-link">Learn more →</span>
      </a>
      <% }) %>
    </div>
  </div>
</section>

<%- include('../partials/cta-band') %>
<%- include('../partials/footer') %>
