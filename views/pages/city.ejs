<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<section class="page-hero">
  <div class="container">
    <div class="breadcrumb"><a href="/">Home</a> → <a href="/locations">Locations</a> → <a href="/cleaning-services-<%= city.stateSlug %>"><%= city.state %></a> → <%= city.name %></div>
    <div class="city-hero-inner">
      <div class="city-badge"><%= city.stateAbbr %></div>
      <h1>House Cleaning in<br><em><%= city.name %>, <%= city.stateAbbr %></em></h1>
      <p class="page-desc">Professional, vetted cleaners serving <%= city.name %> and surrounding areas including <%= city.neighborhoods.join(', ') %>. Same-day service available. Call now for a free instant quote.</p>
      <div class="city-actions">
        <a href="<%= site.phoneHref %>" class="btn-primary btn-large pulse-btn">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call <%= site.phone %>
        </a>
        <a href="/get-a-quote" class="btn-ghost">Get Free Quote</a>
      </div>
    </div>
  </div>
</section>

<section class="section section-cream">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Our Services in <%= city.name %></span>
      <h2>What We Offer</h2>
    </div>
    <div class="services-grid">
      <% site.services.forEach(service => { %>
      <a href="/services/<%= service.slug %>" class="service-card">
        <div class="service-icon"><%= service.icon %></div>
        <h3><%= service.name %></h3>
        <p><%= service.shortDesc %></p>
        <div class="service-price"><%= service.price %></div>
        <span class="service-link">Learn more →</span>
      </a>
      <% }) %>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Areas We Serve</span>
      <h2>Neighborhoods in <%= city.name %></h2>
      <p>We serve all neighborhoods across <%= city.name %> and the greater metro area.</p>
    </div>
    <div class="neighborhoods-grid">
      <% city.neighborhoods.forEach(n => { %>
      <div class="neighborhood-pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <%= n %>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="section section-dark">
  <div class="container">
    <div class="section-header light">
      <span class="section-tag">Why Choose Us</span>
      <h2>The FyndLocals Difference in <%= city.name %></h2>
    </div>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon">🔍</div>
        <h3>Thoroughly Vetted</h3>
        <p>Every cleaner serving <%= city.name %> has passed background checks, reference verification, and in-person interviews.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">⚡</div>
        <h3>Same-Day Service</h3>
        <p>Need cleaning today? We match you with available cleaners in <%= city.name %> fast — often within hours.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">💯</div>
        <h3>Satisfaction Guaranteed</h3>
        <p>Not happy? We send someone back for free. No arguments, no hassle — just a clean home.</p>
      </div>
      <div class="why-card">
        <div class="why-icon">🛡️</div>
        <h3>Fully Insured</h3>
        <p>All cleaners are insured and bonded. Your <%= city.name %> home is protected every step of the way.</p>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/cta-band') %>
<%- include('../partials/footer') %>
