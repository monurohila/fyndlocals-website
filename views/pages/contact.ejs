<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<section class="page-hero-simple">
  <div class="container">
    <div class="breadcrumb"><a href="/">Home</a> → Contact</div>
    <h1>Get a Free Quote</h1>
    <p class="page-desc">Call us now for an instant, no-obligation quote. We're available 7 days a week.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <h2>Contact Us</h2>
        <div class="contact-item">
          <div class="contact-icon">📞</div>
          <div>
            <h3>Phone</h3>
            <a href="<%= site.phoneHref %>" class="contact-link"><%= site.phone %></a>
            <p>Mon–Sun, 7am–9pm local time</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">✉️</div>
          <div>
            <h3>Email</h3>
            <a href="mailto:<%= site.email %>" class="contact-link"><%= site.email %></a>
            <p>We respond within 2 hours</p>
          </div>
        </div>
        <div class="contact-item">
          <div class="contact-icon">📍</div>
          <div>
            <h3>Service Area</h3>
            <p>Serving 30+ cities across<br>12 US states</p>
          </div>
        </div>
        <a href="<%= site.phoneHref %>" class="btn-primary btn-large pulse-btn" style="margin-top:32px;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          Call Now – Free Quote
        </a>
      </div>
      <div class="contact-form-wrap">
        <h2>Quick Quote Form</h2>
        <p>Fill out the form and we'll call you back within 15 minutes.</p>
        <form class="contact-form" onsubmit="handleForm(event)">
          <div class="form-row">
            <div class="form-group"><label>First Name</label><input type="text" placeholder="John" required></div>
            <div class="form-group"><label>Last Name</label><input type="text" placeholder="Smith" required></div>
          </div>
          <div class="form-group"><label>Phone Number</label><input type="tel" placeholder="(555) 000-0000" required></div>
          <div class="form-group"><label>Email</label><input type="email" placeholder="john@email.com"></div>
          <div class="form-group">
            <label>Service Needed</label>
            <select required>
              <option value="">Select a service</option>
              <% site.services.forEach(s => { %><option><%= s.name %></option><% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Your City</label>
            <select required>
              <option value="">Select your city</option>
              <% site.cities.forEach(c => { %><option><%= c.name %>, <%= c.stateAbbr %></option><% }) %>
            </select>
          </div>
          <div class="form-group"><label>Message (optional)</label><textarea rows="3" placeholder="Any special instructions or questions..."></textarea></div>
          <button type="submit" class="btn-primary" style="width:100%;justify-content:center;">Request My Free Quote</button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
<script>
function handleForm(e) {
  e.preventDefault();
  alert('Thank you! We\'ll call you within 15 minutes.');
}
</script>
