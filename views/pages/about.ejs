<%- include('../partials/head') %>
<%- include('../partials/nav') %>

<section class="page-hero-simple">
  <div class="container">
    <div class="breadcrumb"><a href="/">Home</a> → About</div>
    <h1>About FyndLocals</h1>
    <p class="page-desc">We're on a mission to make professional cleaning accessible to every American household.</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="about-grid">
      <div class="about-text">
        <h2>Our Story</h2>
        <p>FyndLocals was built to solve a simple problem: finding a trustworthy, affordable cleaner in the US was too hard. Booking was complicated, quality was inconsistent, and prices were opaque.</p>
        <p>We built a platform that connects homeowners with vetted local cleaners — transparent pricing, instant quotes, same-day availability, and a rock-solid satisfaction guarantee.</p>
        <p>Today we serve over 30 cities across the USA and have helped 50,000+ households get their time back.</p>
        <div class="stats-grid" style="margin-top:40px;">
          <% site.stats.forEach(stat => { %>
          <div class="stat-item">
            <span class="stat-value"><%= stat.value %></span>
            <span class="stat-label"><%= stat.label %></span>
          </div>
          <% }) %>
        </div>
      </div>
      <div class="about-values">
        <h2>Our Values</h2>
        <div class="value-item"><div class="value-icon">🔍</div><div><h3>Transparency</h3><p>Clear pricing, no hidden fees. You know exactly what you're paying before we arrive.</p></div></div>
        <div class="value-item"><div class="value-icon">🛡️</div><div><h3>Trust</h3><p>Every cleaner is background-checked, insured, and personally verified before joining our platform.</p></div></div>
        <div class="value-item"><div class="value-icon">💯</div><div><h3>Accountability</h3><p>Not satisfied? We make it right — always. No hassle, no arguments.</p></div></div>
        <div class="value-item"><div class="value-icon">🌍</div><div><h3>Community</h3><p>We support local cleaners with fair pay, steady work, and a platform that values their expertise.</p></div></div>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/cta-band') %>
<%- include('../partials/footer') %>
