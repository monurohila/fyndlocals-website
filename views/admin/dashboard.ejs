<%- include('layout-top') %>

<% if (flash) { %>
<div class="alert alert-<%= flash.type === 'success' ? 'success' : 'error' %>"><%= flash.msg %></div>
<% } %>

<!-- STATS -->
<div class="stats-row">
  <div class="stat-card highlight">
    <div class="stat-card-label">Tracking Number</div>
    <div class="stat-card-value" style="font-size:20px;"><%= cfg.phone %></div>
    <div class="stat-card-sub"><a href="/admin/settings" style="color:#00b4a0;">Change number →</a></div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Total Pages</div>
    <div class="stat-card-value"><%= stats.pages %></div>
    <div class="stat-card-sub">Live & indexed</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Cities Covered</div>
    <div class="stat-card-value"><%= stats.cities %></div>
    <div class="stat-card-sub">Across <%= stats.states %> states</div>
  </div>
  <div class="stat-card">
    <div class="stat-card-label">Services</div>
    <div class="stat-card-value"><%= stats.services %></div>
    <div class="stat-card-sub">Active service pages</div>
  </div>
</div>

<!-- TWO COLUMNS -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">

  <!-- Quick Actions -->
  <div class="card">
    <div class="card-header"><span class="card-title">Quick Actions</span></div>
    <div class="card-body" style="display:flex;flex-direction:column;gap:10px;">
      <a href="/admin/settings" class="btn btn-teal" style="justify-content:flex-start;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        Update Tracking Phone Number
      </a>
      <a href="/admin/settings" class="btn btn-outline" style="justify-content:flex-start;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/></svg>
        Edit Site Settings
      </a>
      <a href="/admin/pages" class="btn btn-outline" style="justify-content:flex-start;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        View All Pages
      </a>
      <a href="/admin/locations" class="btn btn-outline" style="justify-content:flex-start;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Manage Locations
      </a>
      <a href="/" target="_blank" class="btn btn-outline" style="justify-content:flex-start;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        View Live Website
      </a>
    </div>
  </div>

  <!-- Pay Per Call Setup Status -->
  <div class="card">
    <div class="card-header"><span class="card-title">Pay Per Call Checklist</span></div>
    <div class="card-body">
      <div style="display:flex;flex-direction:column;gap:10px;">
        <% const checks = [
          { label: 'Tracking phone number set', done: cfg.phone !== '(800) 555-0100' },
          { label: 'Google Analytics connected', done: !!cfg.googleAnalyticsId },
          { label: 'Facebook Pixel added', done: !!cfg.facebookPixelId },
          { label: 'Ringba number configured', done: !!cfg.ringbaNumber },
          { label: 'Real email address set', done: cfg.email !== 'hello@fyndlocals.com' },
        ]; %>
        <% checks.forEach(c => { %>
        <div style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:8px;background:<%= c.done ? '#f0fff4' : '#fffbeb' %>;border:1px solid <%= c.done ? '#c6f6d5' : '#fde68a' %>;">
          <span style="font-size:16px;"><%= c.done ? '✅' : '⚠️' %></span>
          <span style="font-size:13px;color:<%= c.done ? '#276749' : '#92400e' %>;font-weight:500;"><%= c.label %></span>
          <% if (!c.done) { %><a href="/admin/settings" style="margin-left:auto;font-size:12px;color:#d97706;">Fix →</a><% } %>
        </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>

<!-- Site Info -->
<div class="card">
  <div class="card-header"><span class="card-title">Current Site Configuration</span></div>
  <div class="card-body">
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
      <div>
        <div style="font-size:12px;color:var(--muted);font-weight:500;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.05em;">Site Name</div>
        <div style="font-size:15px;font-weight:500;"><%= cfg.siteName %></div>
      </div>
      <div>
        <div style="font-size:12px;color:var(--muted);font-weight:500;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.05em;">Email</div>
        <div style="font-size:15px;font-weight:500;"><%= cfg.email %></div>
      </div>
      <div>
        <div style="font-size:12px;color:var(--muted);font-weight:500;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.05em;">Phone</div>
        <div style="font-size:15px;font-weight:500;color:#00b4a0;"><%= cfg.phone %></div>
      </div>
      <div>
        <div style="font-size:12px;color:var(--muted);font-weight:500;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.05em;">Google Analytics</div>
        <div style="font-size:14px;"><%= cfg.googleAnalyticsId || '<span style="color:#d97706">Not set</span>' %></div>
      </div>
      <div>
        <div style="font-size:12px;color:var(--muted);font-weight:500;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.05em;">Facebook Pixel</div>
        <div style="font-size:14px;"><%= cfg.facebookPixelId || '<span style="color:#d97706">Not set</span>' %></div>
      </div>
      <div>
        <div style="font-size:12px;color:var(--muted);font-weight:500;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.05em;">Ringba Number</div>
        <div style="font-size:14px;"><%= cfg.ringbaNumber || '<span style="color:#d97706">Not set</span>' %></div>
      </div>
    </div>
  </div>
</div>

<%- include('layout-bottom') %>
